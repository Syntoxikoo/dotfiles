// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true,
  },
  "use_system_window_tabs": true,

  "file_scan_exclusions": [
    ".obsidian/",
    ".git/",
    "*.png",
    "*.DS_Store",
    "htmlcov",
    ".ruff_cache",
    ".pytest_cache",
    ".mypy_cache",
    ".hypothesis",
    ".benchmarks",
    ".cleanup-reports",
    "__pycache__",
    ".coverage",
    ".trash",
    ".venv/",
  ],

  "languages": {
    "Python": {
      "show_edit_predictions": true,
      "language_servers": ["ruff", "ty"],
    },
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "profiles": {
      "planning-work": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "gemini-3-pro-preview",
        },
        "name": "Planning_work",
        "tools": {
          "copy_path": true,
          "move_path": false,
          "list_directory": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "create_directory": true,
          "edit_file": true,
          "thinking": true,
          "now": false,
          "open": true,
          "read_file": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-context7": {
            "tools": {
              "query-docs": true,
            },
          },
        },
      },
      "ui-interaction-expert": {
        "name": "UI_interaction_expert",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
      "document": {
        "name": "Document",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "icon_theme": "Catppuccin Mocha",
  "vim_mode": true,
  "terminal": {
    "shell": "system",
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": "0xProto Nerd Font",
    "env": { "UV_ENV_FILE": ".env" },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
    "folds": false,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["3270 Nerd Font", "Courier New", "monospace"],
  "buffer_font_family": "0xProto Nerd Font",
  "linked_edits": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "title_bar": {
    "show_user_menu": false,
    "show_user_picture": false,
    "show_onboarding_banner": false,
  },
  "tab_bar": { "show": false },
  "toolbar": { "quick_actions": false },
  // "status_bar": { "experimental.show": false },
  "project_panel": {
    "hide_root": true,
    "hide_hidden": false,
    "auto_fold_dirs": false,
    "starts_open": false,
    "scrollbar": { "show": "never" },
    "indent_guides": { "show": "never" },
  },
  "outline_panel": {
    "file_icons": true,
    "dock": "left",
    "scrollbar": { "show": "never" },
  },
  "file_finder": { "modal_max_width": "small" },
  "scrollbar": { "show": "never" },
  "indent_guides": { "coloring": "indent_aware" },
  "agent_buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "drag_and_drop_selection": { "enabled": false },
  // "seed_search_query_from_cursor": "never",
  "extend_comment_on_newline": false,
  "colorize_brackets": true,
  "auto_indent_on_paste": false,
  "inline_code_actions": false,
  "when_closing_with_no_tabs": "keep_window_open",
}
